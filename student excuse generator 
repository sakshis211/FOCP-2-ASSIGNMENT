#include <iostream>
#include <vector>
#include <string>
#include <ctime>
#include <cstdlib>

using namespace std;

int main() {
    srand(static_cast<unsigned int>(time(0)));

    string studentName;
    cout << "Enter your name, professional excuse-maker: ";
    getline(cin, studentName);

    vector<string> excuses = {
        "{name} couldn't complete the assignment because the laptop battery died unexpectedly.",
        "{name} tried finishing the homework, but the internet stopped working.",
        "{name} was ready to submit when the file mysteriously disappeared.",
        "The dog didn't eat the homework, it actually uploaded it to the wrong cloud, {name} claims.",
        "{name}'s keyboard suddenly decided to speak only in emojis.",
        "A localized solar flare only affected {name}'s house and Wi-Fi.",
        "{name} spent all night debugging a 'Hello World' program.",
        "{name} thought the deadline was in 2027.",
        "Gravity was extra strong today, so {name} couldn't lift the laptop.",
        "{name} accidentally joined a secret society and had to go on a quest."
    };

    int index = rand() % excuses.size();
    string finalExcuse = excuses[index];

    // Simple placeholder replacement
    size_t pos = finalExcuse.find("{name}");
    if (pos != string::npos) {
        finalExcuse.replace(pos, 6, studentName); // 6 is the length of "{name}"
    }

    cout << "\n--- YOUR OFFICIAL EXCUSE ---" << endl;
    cout << finalExcuse << endl;

    return 0;
}
